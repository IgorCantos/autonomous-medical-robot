{
  "info": {
    "name": "🏥 Assistente Médico Inteligente",
    "description": "API para consultas médicas com IA e gestão de pacientes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "medical-assistant-v1"
  },
  "item": [
    {
      "name": "🤖 Consultas Médicas",
      "item": [
        {
          "name": "Processar Query Médica",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has session_id\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('session_id');",
                  "    pm.expect(jsonData.session_id).to.be.a('string');",
                  "});",
                  "",
                  "pm.test(\"Response has required fields\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('patientId');",
                  "    pm.expect(jsonData).to.have.property('query');",
                  "    pm.expect(jsonData).to.have.property('response');",
                  "    pm.expect(jsonData).to.have.property('responseTime');",
                  "});",
                  "",
                  "// Salva session_id para usar nos próximos testes",
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('sessionId', jsonData.session_id);",
                  "    pm.collectionVariables.set('patientId', jsonData.patientId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Considerando minhas alergias, quais medicamentos devo evitar para dor de cabeça?\",\n  \"patientId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/query",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query"]
            }
          },
          "response": []
        }
      ],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript"
          }
        }
      ],
      "protocolProfileBehavior": {}
    },
