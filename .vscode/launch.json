{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Medical Assistant (Normal)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/index.js",
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "restart": true,
      "runtimeExecutable": "node",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Debug Medical Assistant (Attach)",
      "type": "node",
      "request": "attach",
      "port": 8080,
      "restart": true,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "${workspaceFolder}",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Debug Medical Assistant (Start with Debugger)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/index.js",
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "restart": true,
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect=0.0.0.0:8080"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}